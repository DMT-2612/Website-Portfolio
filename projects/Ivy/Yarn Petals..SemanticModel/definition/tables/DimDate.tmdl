table DimDate
	lineageTag: 8ffbb2bd-f280-4863-bc2f-cd79c71374b3
	dataCategory: Time

	column Date
		dataType: dateTime
		isKey
		formatString: Short Date
		lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567890
		summarizeBy: none
		sourceColumn: [Date]

		annotation SummarizationSetBy = Automatic

	column Year
		dataType: int64
		formatString: 0
		lineageTag: b2c3d4e5-f6a7-8901-bcde-f12345678901
		summarizeBy: none
		sourceColumn: [Year]

		annotation SummarizationSetBy = Automatic

	column 'Month Number'
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: c3d4e5f6-a7b8-9012-cdef-123456789012
		summarizeBy: none
		sourceColumn: [Month Number]

		annotation SummarizationSetBy = Automatic

	column Month
		dataType: string
		lineageTag: d4e5f6a7-b8c9-0123-def0-234567890123
		summarizeBy: none
		sourceColumn: [Month]
		sortByColumn: 'Month Number'

		annotation SummarizationSetBy = Automatic

	column Year-Month
		dataType: string
		lineageTag: e5f6a7b8-c9d0-1234-ef01-345678901234
		summarizeBy: none
		sourceColumn: [Year-Month]
		sortByColumn: 'Year-Month Sort'

		annotation SummarizationSetBy = Automatic

	column 'Year-Month Sort'
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: f6a7b8c9-d0e1-2345-f012-456789012345
		summarizeBy: none
		sourceColumn: [Year-Month Sort]

		annotation SummarizationSetBy = Automatic

	partition DimDate = calculated
		mode: import
		source =
				ADDCOLUMNS (
				    CALENDAR ( MIN ( Orders[Date] ), MAX ( Orders[Date] ) ),
				    "Year", YEAR ( [Date] ),
				    "Month Number", MONTH ( [Date] ),
				    "Month", FORMAT ( [Date], "MMM" ),
				    "Year-Month", FORMAT ( [Date], "YYYY-MM" ),
				    "Year-Month Sort", YEAR ( [Date] ) * 100 + MONTH ( [Date] )
				)

	annotation PBI_Id = DimDate

	annotation __PBI_DateTable = true

	annotation __PBI_DateTableColumn = Date

