model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-AU
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_ProTooling = ["DevMode","TMDLView_Desktop"]

annotation PBI_QueryOrder = ["Orders"]

ref table DimDate
ref table Metrics
ref table Parameter
ref table Orders

ref cultureInfo en-US

